ARB_APP_NAME=crypto-arb-scanner
ARB_APP_ENV=dev
ARB_REQUEST_TIMEOUT_SECONDS=10
ARB_DEFAULT_SYMBOLS_CSV=BTC,ETH,SOL

ARB_ENABLE_BINANCE=true
ARB_ENABLE_OKX=true
ARB_ENABLE_HYPERLIQUID=true
ARB_ENABLE_LIGHTER=true

ARB_BINANCE_BASE_URL=https://fapi.binance.com
ARB_OKX_BASE_URL=https://www.okx.com
# If your region needs OKX US endpoints, override with:
# ARB_OKX_WS_URL=wss://wsus.okx.com:8443/ws/v5/public
ARB_OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/public
ARB_HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
ARB_HYPERLIQUID_DEX=
# Lighter read-only websocket works better from restricted regions.
ARB_LIGHTER_WS_URL=wss://mainnet.zklighter.elliot.ai/stream?readonly=true
ARB_LIGHTER_MARKETS_URL=https://explorer.elliot.ai/api/markets
ARB_LIGHTER_WS_TIMEOUT_SECONDS=5
ARB_OKX_WS_TIMEOUT_SECONDS=5
